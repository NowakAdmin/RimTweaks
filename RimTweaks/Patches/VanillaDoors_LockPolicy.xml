<?xml version="1.0" encoding="utf-8"?>
<!--
  Adds door lock policy comp to vanilla Autodoor.
  No external dependencies — implemented in RimTweaks.dll.

  Lock policy (gizmo on selected door, click to cycle):
    Default                             — vanilla behavior
    Everyone                            — all pawns pass freely
    Only colonists and animals          — blocks visitors/hostiles
    Only colonists, animals and friendlies
    Only drafted                        — blocks everyone except drafted colonists
-->
<Patch>

  <!-- Add our comp to Autodoor's comps list -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="Autodoor"]/comps</xpath>
    <value>
      <li Class="RimTweaks.DoorLock.CompProperties_DoorLockPolicy"/>
    </value>
  </Operation>

</Patch>
