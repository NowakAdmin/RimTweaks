<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="PlantBase">
    <defName>NOAD_Plant_RimCorn</defName>
    <label>RimCorn plant</label>
    <description>A genetically enhanced strain of corn that thrives only in exceptionally fertile soil, but rewards careful farmers with extraordinary yields. Demands the best — and delivers accordingly.</description>
    <statBases>
      <MaxHitPoints>150</MaxHitPoints>
      <Nutrition>0.4</Nutrition>
    </statBases>
    <graphicData>
      <texPath>Things/Plant/CornPlant</texPath>
      <graphicClass>Graphic_Random</graphicClass>
    </graphicData>
    <selectable>true</selectable>
    <pathCost>14</pathCost>
    <ingestible />
    <plant>
      <fertilityMin>1.00</fertilityMin>
      <fertilitySensitivity>2.00</fertilitySensitivity>
      <dieIfLeafless>true</dieIfLeafless>
      <harvestTag>Standard</harvestTag>
      <harvestedThingDef>RawCorn</harvestedThingDef>
      <harvestYield>22</harvestYield>
      <sowTags>
        <li>Ground</li>
      </sowTags>
      <topWindExposure>0.35</topWindExposure>
      <growDays>11.3</growDays>
      <immatureGraphicPath>Things/Plant/CornPlant_Immature</immatureGraphicPath>
      <visualSizeRange>0.5~1.4</visualSizeRange>
      <wildOrder>2</wildOrder>
      <purpose>Food</purpose>
      <humanFoodPlant>true</humanFoodPlant>
    </plant>
  </ThingDef>

</Defs>
