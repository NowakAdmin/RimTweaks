<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>NOAD_ProductionServer</defName>
    <label>production server</label>
    <description>A networked computation server that feeds real-time optimization data to nearby workbenches, increasing work speed by 10%. Up to 10 servers can boost a single workbench.</description>
    <graphicData>
      <texPath>Things/Building/Misc/ServerThin</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(1,2)</drawSize>
      <damageData>
        <cornerTL>Damage/Corner</cornerTL>
        <cornerTR>Damage/Corner</cornerTR>
        <cornerBL>Damage/Corner</cornerBL>
        <cornerBR>Damage/Corner</cornerBR>
      </damageData>
    </graphicData>
    <uiIconPath>Things/Building/Misc/ServerThin_south</uiIconPath>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <pathCost>50</pathCost>
    <fillPercent>0.5</fillPercent>
    <size>(1,2)</size>
    <rotatable>true</rotatable>
    <selectable>true</selectable>
    <minifiedDef>MinifiedThing</minifiedDef>
    <thingCategories>
      <li>BuildingsFurniture</li>
    </thingCategories>
    <statBases>
      <MaxHitPoints>120</MaxHitPoints>
      <WorkToBuild>1200</WorkToBuild>
      <Mass>15</Mass>
      <Flammability>0.5</Flammability>
      <Beauty>-3</Beauty>
    </statBases>
    <costList>
      <Steel>80</Steel>
      <ComponentIndustrial>3</ComponentIndustrial>
    </costList>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>100</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_Breakdownable"/>
      <li Class="CompProperties_Glower">
        <glowRadius>3</glowRadius>
        <glowColor>(80,140,255,0)</glowColor>
      </li>
      <li Class="CompProperties_Facility">
        <statOffsets>
          <WorkTableWorkSpeedFactor>0.10</WorkTableWorkSpeedFactor>
        </statOffsets>
        <maxDistance>10</maxDistance>
        <maxSimultaneous>10</maxSimultaneous>
      </li>
    </comps>
    <designationCategory>Production</designationCategory>
    <researchPrerequisites>
      <li>Electricity</li>
    </researchPrerequisites>
    <constructionSkillPrerequisite>5</constructionSkillPrerequisite>
    <placeWorkers>
      <li>PlaceWorker_ShowFacilitiesConnections</li>
    </placeWorkers>
  </ThingDef>

</Defs>
